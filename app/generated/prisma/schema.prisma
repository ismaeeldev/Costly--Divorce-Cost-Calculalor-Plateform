generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// USER
// =====================
model User {
  id               String    @id @default(uuid())
  name             String?
  email            String    @unique
  password         String?
  resetToken       String?
  resetTokenExpiry DateTime?

  // Access Control
  accessType         String  @default("NONE") // NONE | ENTRY | CORE | SUBSCRIPTION
  hasFullAccess      Boolean @default(false) // $127 unlock
  entryPurchased     Boolean @default(false) // $19 product
  canUseSubscription Boolean @default(false)
  hasAIAdvisor       Boolean @default(false)

  // Subscription
  subscriptionId     String?
  subscriptionStatus String?

  stripeCustomerId String? @unique
  stripeSubId      String?

  // Add-on flags (separate tracking)
  assetSplit       Boolean @default(false) // ASSET_SPLIT
  retirementImpact Boolean @default(false) // RETIREMENT
  vaDisability     Boolean @default(false) // VA_DISABILITY
  housingScenario  Boolean @default(false) // HOUSING

  // Relations
  addons    Addon[]
  scenarios Scenario[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// SCENARIO
// =====================
model Scenario {
  id     String @id @default(uuid())
  userId String
  name   String @default("Scenario 1")

  // INPUT DATA
  userIncome     Float
  spouseIncome   Float
  childrenCount  Int
  custodyPercent Float

  // EXPENSES
  mortgage      Float @default(0)
  childcare     Float @default(0)
  school        Float @default(0)
  activities    Float @default(0)
  utilities     Float @default(0)
  insurance     Float @default(0)
  otherExpenses Float @default(0)

  // OPTIONAL INPUTS
  savings    Float?
  retirement Float?
  homeEquity Float?

  // PREMIUM ADD-ONS (STORED AS JSON)
  assetSplit       Json?
  retirementImpact Json?
  vaDisability     Json?
  housingScenario  Json?

  // RESULT DATA (STORE SNAPSHOT)
  netIncome        Float
  monthlySupport   Float
  totalExpenses    Float
  disposableIncome Float
  realityScore     Float
  realityLevel     String // "green", "yellow", "red"

  isAutoGenerated Boolean @default(false) // 0%, 40%, 50%

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =====================
// ADD-ONS
// =====================
model Addon {
  id     String @id @default(uuid())
  userId String

  type     AddonType
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AddonType {
  ASSET_SPLIT
  RETIREMENT
  VA_DISABILITY
  HOUSING
}

// =====================
// PAYMENTS
// =====================
model Payment {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  stripeSessionId String  @unique
  stripePaymentId String?
  stripePriceId   String?

  amount   Int
  currency String @default("usd")

  // ENTRY | CORE | ADDON | SUBSCRIPTION
  productType ProductType

  createdAt DateTime @default(now())
}

enum ProductType {
  ENTRY // $19
  CORE // $127
  ADDON
  SUBSCRIPTION
}

// =====================
// STRIPE EVENTS
// =====================
model StripeEvent {
  id      String @id @default(uuid())
  eventId String @unique
  type    String

  processed Boolean @default(false)

  createdAt DateTime @default(now())
}

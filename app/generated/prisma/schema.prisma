generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// USER
// =====================
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String?

  // Access Control
  hasFullAccess  Boolean @default(false) // $127 unlock
  entryPurchased Boolean @default(false) // $19 product

  // Subscription
  subscriptionStatus String?
  stripeCustomerId   String?
  stripeSubId        String?

  // Relations
  addons    Addon[]
  scenarios Scenario[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// SCENARIO
// =====================
model Scenario {
  id     String @id @default(uuid())
  userId String
  name   String @default("Scenario 1")

  // INPUT DATA
  userIncome     Float
  spouseIncome   Float
  childrenCount  Int
  custodyPercent Float

  // EXPENSES
  mortgage      Float @default(0)
  childcare     Float @default(0)
  school        Float @default(0)
  activities    Float @default(0)
  utilities     Float @default(0)
  insurance     Float @default(0)
  otherExpenses Float @default(0)

  // OPTIONAL INPUTS
  savings    Float?
  retirement Float?
  homeEquity Float?

  // RESULT DATA (STORE SNAPSHOT)
  netIncome        Float
  monthlySupport   Float
  totalExpenses    Float
  disposableIncome Float
  realityScore     Float
  realityLevel     String // "green", "yellow", "red"

  isAutoGenerated Boolean @default(false) // 0%, 40%, 50%

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =====================
// ADD-ONS
// =====================
model Addon {
  id     String @id @default(uuid())
  userId String

  type     AddonType
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AddonType {
  ASSET_SPLIT
  RETIREMENT
  VA_DISABILITY
  HOUSING
}

// =====================
// PAYMENTS
// =====================
model Payment {
  id     String  @id @default(uuid())
  userId String?

  amount   Float
  currency String @default("usd")

  productType ProductType
  stripeId    String      @unique

  status String // succeeded, pending, failed

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum ProductType {
  ENTRY // $19
  FULL_UNLOCK // $127
  ADDON
  SUBSCRIPTION
}

// =====================
// STRIPE EVENTS
// =====================
model StripeEvent {
  id      String @id @default(uuid())
  eventId String @unique
  type    String

  processed Boolean @default(false)

  createdAt DateTime @default(now())
}
